 def compact(s: str) -> str:
     return re.sub(r'\s+', '', (s or '').replace('\ufeff','')).strip()
 
+def _is_expect_meta_line(line: str) -> bool:
+    """Beklenen çıktı dosyasındaki üretim/metaveri satırlarını ayıklar."""
+    st=(line or '').strip().replace('\ufeff','')
+    low=st.lower().replace(' ', '').replace('\t','')
+    if not low:
+        return False
+    if low.startswith('#source:') or low.startswith('#source='):
+        return True
+    if low.startswith('#expect_source:') or low.startswith('#expectsource:'):
+        return True
+    if low.startswith('#embedded_expect_output') or low.startswith('#embeddedexpectoutput'):
+        return True
+    if low.startswith('#expect_output') or low.startswith('#expectoutput'):
+        return True
+    if low.startswith('#generated_from') or low.startswith('#generatedfrom'):
+        return True
+    return False
+
+def _clean_expect_body(body: str) -> str:
+    lines=[]
+    for line in (body or '').splitlines():
+        if _is_expect_meta_line(line):
+            continue
+        lines.append(line)
+    return '\n'.join(lines).strip('\r\n')
+
