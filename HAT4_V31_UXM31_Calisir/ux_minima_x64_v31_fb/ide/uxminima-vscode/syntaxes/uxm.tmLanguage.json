{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "UX-MINIMA",
  "scopeName": "source.uxm",
  "patterns": [
    {"include": "#comments"},
    {"include": "#pragmas"},
    {"include": "#strings"},
    {"include": "#macros"},
    {"include": "#printString"},
    {"include": "#meta"},
    {"include": "#addressing"},
    {"include": "#repeat"},
    {"include": "#branch"},
    {"include": "#commands"}
  ],
  "repository": {
    "comments": {
      "patterns": [
        {"name": "comment.line.number-sign.uxm", "match": "#.*$"}
      ]
    },
    "pragmas": {
      "patterns": [
        {"name": "keyword.control.pragma.uxm", "match": "^\\s*#(mode|cell|memory|bounds|overflow|compare|endian|arge)\\b.*$"}
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "meta.stringdef.uxm",
          "begin": "\\bs[0-9]+\\s*=\\s*[0-9]+\\s*,\\s*\\{",
          "beginCaptures": {"0": {"name": "storage.type.stringdef.uxm"}},
          "end": "\\}",
          "patterns": [
            {"name": "constant.character.escape.uxm", "match": "\\\\[nrt{}\\\\]"}
          ]
        }
      ]
    },
    "macros": {
      "patterns": [
        {
          "name": "meta.macrodef.uxm",
          "begin": "\\bm[0-9]+\\s*=\\s*\\{",
          "beginCaptures": {"0": {"name": "entity.name.function.macro.uxm"}},
          "end": "\\}",
          "patterns": [
            {"include": "#meta"},
            {"include": "#addressing"},
            {"include": "#repeat"},
            {"include": "#commands"}
          ]
        }
      ]
    },
    "printString": {
      "patterns": [
        {"name": "support.function.print-string.uxm", "match": "\\bp[0-9]+\\b"}
      ]
    },
    "meta": {
      "patterns": [
        {"name": "support.function.meta.dynamic.uxm", "match": "@#"},
        {"name": "support.function.meta.host.uxm", "match": "@![0-9]{1,3}"},
        {"name": "support.function.meta.uxm", "match": "@[0-9]{1,3}"}
      ]
    },
    "addressing": {
      "patterns": [
        {"name": "variable.parameter.address.uxm", "match": "\\((D@T(?:[+-][0-9]+)?|D@\\(T(?:[+-][0-9]+)?\\)(?:[+-][0-9]+)?|T|T[+-][0-9]+|T:[0-9]+|D:[0-9]+|S:[0-9]+|SP|P|E|F|\\*T|\\*\\(T[+-][0-9]+\\))\\)"}
      ]
    },
    "repeat": {
      "patterns": [
        {"name": "constant.numeric.repeat.uxm", "match": "k[0-9]+"}
      ]
    },
    "branch": {
      "patterns": [
        {"name": "keyword.control.branch.uxm", "match": ":(:|0|z|Z|c|C|o|O|s|S)?[+-][0-9]+"}
      ]
    },
    "commands": {
      "patterns": [
        {"name": "keyword.operator.uxm", "match": "[><+\\-0\\.,\\[\\]\\$%\\?!;&\\|\\^~\\{\\}eE]"}
      ]
    }
  }
}
