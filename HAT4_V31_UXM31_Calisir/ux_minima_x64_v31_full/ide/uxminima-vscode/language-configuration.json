{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    {"open": "[", "close": "]"},
    {"open": "(", "close": ")"},
    {"open": "{", "close": "}"}
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"]
  ],
  "wordPattern": "(@#|@[0-9]+|[spm][0-9]+|[TDSPFE]:?[+-]?[0-9]*|[A-Za-z_][A-Za-z0-9_]*)"
}
